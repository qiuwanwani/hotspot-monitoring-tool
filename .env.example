# ============================================
# 热点监控工具 - 环境变量配置模板
# 复制此文件为 .env 并填写实际配置值
# ============================================

# --------------------------------------------
# 必需配置
# --------------------------------------------

# 数据库连接URL
# SQLite: file:./dev.db
# PostgreSQL: postgresql://user:password@localhost:5432/hotspot_db
# MySQL: mysql://user:password@localhost:3306/hotspot_db
DATABASE_URL="file:./dev.db"

# JWT密钥 - 用于用户认证令牌签名
# 生产环境必须使用强密钥（建议使用随机生成的32位以上字符串）
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# --------------------------------------------
# AI 服务配置（至少配置一个）
# --------------------------------------------

# OpenRouter API (推荐，支持多种模型)
# 获取地址: https://openrouter.ai/keys
OPENROUTER_API_KEY="your-openrouter-api-key"

# OpenAI API
# 获取地址: https://platform.openai.com/api-keys
OPENAI_API_KEY="your-openai-api-key"

# Anthropic API (Claude)
# 获取地址: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY="your-anthropic-api-key"

# AI 服务基础URL（可选，用于自定义端点或代理）
# OpenRouter默认: https://api.openrouter.ai/api/v1
# OpenAI默认: https://api.openai.com/v1
AI_BASE_URL=""

# AI 模型名称（可选，不配置则使用默认模型）
# OpenRouter推荐: openai/gpt-4o-mini, anthropic/claude-3-haiku
# OpenAI推荐: gpt-4o-mini, gpt-4o
AI_MODEL=""

# --------------------------------------------
# 可选配置 - 数据源API
# --------------------------------------------

# Twitter API (需要 twitterapi-io 服务)
# 获取地址: https://www.twitterapi.io/
TWITTER_API_KEY="your-twitterapi-io-key"

# --------------------------------------------
# 可选配置 - 通知服务
# --------------------------------------------

# Web Push 通知密钥
# 生成方法: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"

# 邮件服务配置 (SMTP)
# 支持 Gmail、QQ邮箱、163邮箱、企业邮箱等
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your-email@example.com"
SMTP_PASSWORD="your-smtp-password"

# --------------------------------------------
# 可选配置 - 高级设置
# --------------------------------------------

# 监控任务执行间隔（分钟，默认5分钟）
MONITOR_INTERVAL="5"

# 数据保留天数（默认30天，超过自动清理）
DATA_RETENTION_DAYS="30"

# 日志级别（debug, info, warn, error，默认info）
LOG_LEVEL="info"

# 开发模式（true/false，生产环境请设置为false）
NODE_ENV="development"
